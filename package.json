{
  "name": "inline",
  "private": true,
  "packageManager": "bun@1.3.1",
  "workspaces": [
    "server",
    "cli",
    "web",
    "landing",
    "packages/*",
    "server/packages/*",
    "landing/packages/*",
    "scripts"
  ],
  "scripts": {
    "dev": "cd server && bun run dev",
    "dev:server": "cd server && bun run dev",
    "generate:proto": "cd scripts && bun run generate",
    "db:migrate": "cd server && bun run db:migrate",
    "db:generate": "cd server && bun run db:generate",
    "ios:debug": "bash scripts/ios/open-debug-app.sh",
    "macos:debug": "bash scripts/macos/open-debug-app.sh",
    "cleanup:builds": "cd scripts && bun run cleanup:builds",
    "cleanup:builds:deep": "cd scripts && bun run cleanup:builds:deep"
  },
  "overrides": {
    "@inline-chat/protocol": "workspace:*",
    "@inline-chat/realtime-sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.3.5",
    "oxlint": "^1.39.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "zustand": "^5.0.9"
  }
}
