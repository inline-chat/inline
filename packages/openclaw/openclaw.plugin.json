{
  "id": "inline",
  "name": "Inline",
  "description": "Inline channel plugin (realtime RPC bot token; DMs + chats).",
  "channels": ["inline"],
  "contracts": {
    "tools": [
      "inline_members",
      "inline_update_profile",
      "inline_bot_commands",
      "inline_nudge",
      "inline_forward"
    ]
  },
  "channelEnvVars": {
    "inline": ["INLINE_TOKEN"]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {}
  },
  "channelConfigs": {
    "inline": {
      "schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "name": { "type": "string" },
          "enabled": { "type": "boolean" },
          "baseUrl": { "type": "string" },
          "token": { "type": "string" },
          "tokenFile": { "type": "string" },
          "capabilities": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "replyThreads": { "type": "boolean" }
            }
          },
          "dmPolicy": {
            "default": "pairing",
            "type": "string",
            "enum": ["pairing", "allowlist", "open", "disabled"]
          },
          "allowFrom": {
            "type": "array",
            "items": { "type": "string" }
          },
          "systemPrompt": { "type": "string" },
          "groupAllowFrom": {
            "type": "array",
            "items": { "type": "string" }
          },
          "groupPolicy": {
            "default": "allowlist",
            "type": "string",
            "enum": ["open", "disabled", "allowlist"]
          },
          "groups": {
            "type": "object",
            "propertyNames": { "type": "string" },
            "additionalProperties": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "requireMention": { "type": "boolean" },
                "systemPrompt": { "type": "string" },
                "tools": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "allow": { "type": "array", "items": { "type": "string" } },
                    "alsoAllow": { "type": "array", "items": { "type": "string" } },
                    "deny": { "type": "array", "items": { "type": "string" } }
                  }
                },
                "toolsBySender": {
                  "type": "object",
                  "propertyNames": { "type": "string" },
                  "additionalProperties": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "allow": { "type": "array", "items": { "type": "string" } },
                      "alsoAllow": { "type": "array", "items": { "type": "string" } },
                      "deny": { "type": "array", "items": { "type": "string" } }
                    }
                  }
                }
              }
            }
          },
          "requireMention": { "type": "boolean" },
          "replyToBotWithoutMention": { "type": "boolean" },
          "historyLimit": { "type": "integer", "minimum": 0 },
          "dmHistoryLimit": { "type": "integer", "minimum": 0 },
          "parseMarkdown": { "type": "boolean" },
          "mediaMaxMb": { "type": "number", "exclusiveMinimum": 0 },
          "actions": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "send": { "type": "boolean" },
              "reply": { "type": "boolean" },
              "reactions": { "type": "boolean" },
              "read": { "type": "boolean" },
              "search": { "type": "boolean" },
              "edit": { "type": "boolean" },
              "channels": { "type": "boolean" },
              "participants": { "type": "boolean" },
              "delete": { "type": "boolean" },
              "pins": { "type": "boolean" },
              "permissions": { "type": "boolean" }
            }
          },
          "textChunkLimit": { "type": "integer", "exclusiveMinimum": 0 },
          "chunkMode": { "type": "string", "enum": ["length", "newline"] },
          "streaming": {
            "anyOf": [
              { "type": "boolean" },
              { "type": "string", "enum": ["off", "partial", "block", "progress"] },
              {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "mode": { "type": "string", "enum": ["off", "partial", "block", "progress"] },
                  "chunkMode": { "type": "string", "enum": ["length", "newline"] },
                  "preview": {
                    "type": "object",
                    "additionalProperties": true,
                    "properties": {
                      "chunk": {
                        "type": "object",
                        "additionalProperties": true,
                        "properties": {
                          "minChars": { "type": "integer", "exclusiveMinimum": 0 },
                          "maxChars": { "type": "integer", "exclusiveMinimum": 0 },
                          "breakPreference": {
                            "type": "string",
                            "enum": ["paragraph", "newline", "sentence"]
                          }
                        }
                      },
                      "toolProgress": { "type": "boolean" },
                      "commandText": { "type": "string", "enum": ["raw", "status"] }
                    }
                  },
                  "progress": {
                    "type": "object",
                    "additionalProperties": true,
                    "properties": {
                      "label": {
                        "anyOf": [{ "type": "string" }, { "type": "boolean", "const": false }]
                      },
                      "labels": { "type": "array", "items": { "type": "string" } },
                      "maxLines": { "type": "integer", "exclusiveMinimum": 0 },
                      "render": { "type": "string", "enum": ["text", "rich"] },
                      "toolProgress": { "type": "boolean" },
                      "commandText": { "type": "string", "enum": ["raw", "status"] }
                    }
                  },
                  "block": {
                    "type": "object",
                    "additionalProperties": true,
                    "properties": {
                      "enabled": { "type": "boolean" },
                      "coalesce": {
                        "type": "object",
                        "additionalProperties": true,
                        "properties": {
                          "minChars": { "type": "integer", "exclusiveMinimum": 0 },
                          "maxChars": { "type": "integer", "exclusiveMinimum": 0 },
                          "idleMs": { "type": "integer", "minimum": 0 }
                        }
                      }
                    }
                  }
                }
              }
            ]
          },
          "streamMode": { "type": "string", "enum": ["off", "partial", "block", "progress"] },
          "draftChunk": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "minChars": { "type": "integer", "exclusiveMinimum": 0 },
              "maxChars": { "type": "integer", "exclusiveMinimum": 0 },
              "breakPreference": { "type": "string", "enum": ["paragraph", "newline", "sentence"] }
            }
          },
          "blockStreaming": { "type": "boolean" },
          "streamViaEditMessage": { "type": "boolean" },
          "blockStreamingCoalesce": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "minChars": { "type": "integer", "exclusiveMinimum": 0 },
              "maxChars": { "type": "integer", "exclusiveMinimum": 0 },
              "idleMs": { "type": "integer", "minimum": 0 }
            }
          },
          "commands": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "native": {
                "anyOf": [{ "type": "boolean" }, { "type": "string", "const": "auto" }]
              },
              "nativeSkills": {
                "anyOf": [{ "type": "boolean" }, { "type": "string", "const": "auto" }]
              }
            }
          },
          "accounts": {
            "type": "object",
            "propertyNames": { "type": "string" },
            "additionalProperties": true
          }
        }
      },
      "label": "Inline",
      "description": "OpenClaw channel provider for Inline DMs and chats.",
      "uiHints": {
        "": {
          "label": "Inline",
          "help": "Inline channel provider configuration for realtime bot tokens, direct messages, group chats, and Inline-specific reply behavior."
        },
        "baseUrl": {
          "label": "Inline API Base URL",
          "help": "Inline API base URL. Defaults to https://api.inline.chat."
        },
        "token": {
          "label": "Inline Bot Token",
          "help": "Inline bot token. Use tokenFile or INLINE_TOKEN if you prefer not to store the token in config."
        },
        "tokenFile": {
          "label": "Inline Bot Token File",
          "help": "Path to a file containing the Inline bot token."
        },
        "dmPolicy": {
          "label": "Inline DM Policy",
          "help": "Controls direct-message access: pairing, allowlist, open, or disabled."
        },
        "allowFrom": {
          "label": "Inline DM Allowlist",
          "help": "Inline user IDs allowed to direct-message the bot. Use * only with dmPolicy=open."
        },
        "groupPolicy": {
          "label": "Inline Group Policy",
          "help": "Controls group chat access: allowlist, open, or disabled."
        },
        "groupAllowFrom": {
          "label": "Inline Group Sender Allowlist",
          "help": "Inline user IDs allowed to trigger the bot in groups when groupPolicy=allowlist."
        },
        "requireMention": {
          "label": "Inline Require Mention",
          "help": "Require an explicit bot mention in group chats before routing a message to the agent."
        },
        "replyToBotWithoutMention": {
          "label": "Inline Reply Mention Bypass",
          "help": "Allow replies to bot-authored messages to bypass group mention requirements."
        },
        "capabilities.replyThreads": {
          "label": "Inline Reply Threads",
          "help": "Expose Inline reply-thread chats as OpenClaw native threads."
        },
        "groups": {
          "label": "Inline Group Overrides",
          "help": "Per-group settings keyed by Inline chat ID, including mention and tool policy overrides."
        },
        "actions": {
          "label": "Inline Message Actions",
          "help": "Enable or disable Inline message-tool action groups such as send, reactions, read, edit, participants, pins, and permissions."
        },
        "commands.native": {
          "label": "Inline Native Commands",
          "help": "Controls startup sync for OpenClaw native slash commands."
        },
        "commands.nativeSkills": {
          "label": "Inline Native Skill Commands",
          "help": "Controls whether native skill slash commands are included in startup command sync."
        },
        "streaming": {
          "label": "Inline Streaming Mode",
          "help": "Unified Inline stream preview mode: \"off\" | \"partial\" | \"block\" | \"progress\". \"partial\" and \"progress\" use Inline edit previews for visible answer text; reasoning stays out of the chat-visible lane."
        },
        "streaming.mode": {
          "label": "Inline Streaming Mode",
          "help": "Canonical Inline preview mode: \"off\" | \"partial\" | \"block\" | \"progress\". \"progress\" degrades to answer-only edit previews until Inline has a dedicated progress/reasoning lane."
        },
        "streaming.preview.toolProgress": {
          "label": "Inline Draft Tool Progress",
          "help": "Accepted for config compatibility with native channels. Inline does not render tool-progress text into chat-visible edit previews."
        },
        "streaming.progress.toolProgress": {
          "label": "Inline Progress Tool Lines",
          "help": "Accepted for config compatibility with native channels. Inline keeps progress/tool details out of chat-visible messages."
        },
        "streaming.block.enabled": {
          "label": "Inline Block Streaming",
          "help": "Enable chunked block-style delivery when channels.inline.streaming.mode=\"block\"."
        },
        "streaming.block.coalesce": {
          "label": "Inline Block Streaming Coalesce",
          "help": "Merge streamed Inline block replies before delivery."
        }
      }
    }
  }
}
