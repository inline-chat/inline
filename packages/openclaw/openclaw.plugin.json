      "label": "Inline",
      "description": "OpenClaw channel provider for Inline DMs and chats.",
      "uiHints": {
        "": {
          "label": "Inline",
          "help": "Inline channel provider configuration for realtime bot tokens, direct messages, group chats, and Inline-specific reply behavior."
        },
        "baseUrl": {
          "label": "Inline API Base URL",
          "help": "Inline API base URL. Defaults to https://api.inline.chat."
        },
        "token": {
          "label": "Inline Bot Token",
          "help": "Inline bot token. Use tokenFile or INLINE_TOKEN if you prefer not to store the token in config."
        },
        "tokenFile": {
          "label": "Inline Bot Token File",
          "help": "Path to a file containing the Inline bot token."
        },
        "dmPolicy": {
          "label": "Inline DM Policy",
          "help": "Controls direct-message access: pairing, allowlist, open, or disabled."
        },
        "allowFrom": {
          "label": "Inline DM Allowlist",
          "help": "Inline user IDs allowed to direct-message the bot. Use * only with dmPolicy=open."
        },
        "groupPolicy": {
          "label": "Inline Group Policy",
          "help": "Controls group chat access: allowlist, open, or disabled."
        },
        "groupAllowFrom": {
          "label": "Inline Group Sender Allowlist",
          "help": "Inline user IDs allowed to trigger the bot in groups when groupPolicy=allowlist."
        },
        "requireMention": {
          "label": "Inline Require Mention",
          "help": "Require an explicit bot mention in group chats before routing a message to the agent."
        },
        "replyToBotWithoutMention": {
          "label": "Inline Reply Mention Bypass",
          "help": "Allow replies to bot-authored messages to bypass group mention requirements."
        },
        "capabilities.replyThreads": {
          "label": "Inline Reply Threads",
          "help": "Expose Inline reply-thread chats as OpenClaw native threads."
        },
        "groups": {
          "label": "Inline Group Overrides",
          "help": "Per-group settings keyed by Inline chat ID, including mention and tool policy overrides."
        },
        "actions": {
          "label": "Inline Message Actions",
          "help": "Enable or disable Inline message-tool action groups such as send, reactions, read, edit, participants, pins, and permissions."
        },
        "commands.native": {
          "label": "Inline Native Commands",
          "help": "Controls startup sync for OpenClaw native slash commands."
        },
        "commands.nativeSkills": {
          "label": "Inline Native Skill Commands",
          "help": "Controls whether native skill slash commands are included in startup command sync."
        }
