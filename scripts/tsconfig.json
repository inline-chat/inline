{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": ["bun", "node"]
  },
  "include": ["*.ts", "docker/**/*.ts", "macos/**/*.ts", "tools/**/*.ts"]
}
